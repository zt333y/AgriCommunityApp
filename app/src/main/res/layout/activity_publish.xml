<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌽 发布农产品"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="20dp"/>

        <EditText android:id="@+id/et_pub_name" android:layout_width="match_parent" android:layout_height="50dp" android:hint="商品名称 (如: 散养土鸡蛋)" android:background="#FFFFFF" android:padding="10dp" android:layout_marginBottom="10dp"/>
        <EditText android:id="@+id/et_pub_category" android:layout_width="match_parent" android:layout_height="50dp" android:hint="分类 (如: 肉禽蛋 / 水果)" android:background="#FFFFFF" android:padding="10dp" android:layout_marginBottom="10dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
            <EditText android:id="@+id/et_pub_price" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:hint="单价 (元)" android:inputType="numberDecimal" android:background="#FFFFFF" android:padding="10dp" android:layout_marginRight="5dp"/>
            <EditText android:id="@+id/et_pub_stock" android:layout_width="0dp" android:layout_weight="1" android:layout_height="50dp" android:hint="库存数量" android:inputType="number" android:background="#FFFFFF" android:padding="10dp" android:layout_marginLeft="5dp"/>
        </LinearLayout>

        <EditText android:id="@+id/et_pub_unit" android:layout_width="match_parent" android:layout_height="50dp" android:hint="计量单位 (如: 斤 / 箱 / 枚)" android:background="#FFFFFF" android:padding="10dp" android:layout_marginBottom="10dp"/>

        <EditText android:id="@+id/et_pub_image" android:layout_width="match_parent" android:layout_height="50dp" android:hint="图片网络链接 (必填)" android:text="https://img14.360buyimg.com/n0/jfs/t1/133282/22/16543/123165/5f9780a4Eeb76451a/10f215dff7677db0.jpg" android:background="#FFFFFF" android:padding="10dp" android:layout_marginBottom="10dp"/>

        <EditText android:id="@+id/et_pub_desc" android:layout_width="match_parent" android:layout_height="100dp" android:hint="商品详细描述..." android:gravity="top|left" android:background="#FFFFFF" android:padding="10dp" android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btn_publish"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="立即发布"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:backgroundTint="#67C23A"/>
    </LinearLayout>
</ScrollView>