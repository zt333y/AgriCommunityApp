<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <TextView
            android:id="@+id/tv_leader_order_no"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="订单号: 123"
            android:textSize="14sp"
            android:textColor="#333"/>

        <TextView
            android:id="@+id/tv_leader_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:text="状态"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:id="@+id/layout_items_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_leader_order_no"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#F9F9F9">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 待核销商品明细："
                android:textSize="13sp"
                android:textColor="#666666"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_order_details_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="加载中..."
                android:textSize="14sp"
                android:textColor="#333333"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_leader_action"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_below="@id/layout_items_container"
            android:layout_alignParentRight="true"
            android:layout_marginTop="15dp"
            android:text="操作按钮"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </RelativeLayout>
</androidx.cardview.widget.CardView>