<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="12dp"
    android:layout_marginRight="12dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <TextView
            android:id="@+id/tv_order_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:text="待发货"
            android:textColor="#FF9800"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_order_no"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toLeftOf="@id/tv_order_status"
            android:layout_marginRight="10dp"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="订单号: 123456789"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:id="@+id/layout_order_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_order_no"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="#F9F9F9"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tv_order_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_order_items"
            android:layout_marginTop="15dp"
            android:text="下单时间: 2026-05-01"
            android:textColor="#999999"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tv_order_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_order_items"
            android:layout_alignParentRight="true"
            android:layout_marginTop="10dp"
            android:text="实付: ￥0.00"
            android:textColor="#F44336"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_receive"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_below="@id/tv_order_amount"
            android:layout_alignParentRight="true"
            android:layout_marginTop="10dp"
            android:text="确认收货"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:textSize="13sp"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_review"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_below="@id/tv_order_amount"
            android:layout_alignParentRight="true"
            android:layout_marginTop="10dp"
            android:text="评价订单"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFC107"
            android:textSize="13sp"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:visibility="gone" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>